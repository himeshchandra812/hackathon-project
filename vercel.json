{
  "buildCommand": "yarn build",
  "devCommand": "yarn dev",
  "installCommand": "yarn install",
  "framework": "vite",
  "env": [
    "GEMINI_API_KEY",
    "GEMINI_API_KEY2",
    "SARVAM_API_KEY",
    "NODE_ENV",
    "PORT"
  ],
  "functions": {
    "server.ts": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
